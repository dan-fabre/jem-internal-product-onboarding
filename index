<!-- ═══════════ WELCOME SCREEN ═══════════ -->
<div class="welcome-screen" id="welcome">
  <div class="welcome-content">
    <div class="jem-logo">jem</div>
    <h1>Welcome to <span>Jem HR</span></h1>
    <p>Your complete product onboarding guide. Master the Jem Dashboard, Admin Portal, and WhatsApp Chatbot through interactive modules, step-by-step walkthroughs, and knowledge checks.</p>
    <form class="welcome-form" id="loginForm" action="https://jemhr.1password.com" method="post" onsubmit="event.preventDefault();startOnboarding();" autocomplete="on">
      <input type="email" class="welcome-input" id="traineeEmail" name="email" placeholder="Your @jemhr.com email address" autocomplete="username email" oninput="checkWelcomeForm()">
      <div class="password-field-wrap">
        <input type="password" class="welcome-input" id="traineePassword" name="password" placeholder="Password" autocomplete="current-password" oninput="checkPasswordStrength(this.value);checkWelcomeForm()" onkeydown="if(event.key==='Enter'){event.preventDefault();document.getElementById('startBtn').click();}">
        <button type="button" class="password-toggle" onclick="togglePasswordVisibility()" tabindex="-1">👁</button>
      </div>
      <div class="pw-strength-wrap" id="pwStrengthWrap" style="display:none;">
        <div class="pw-strength-bar-track"><div class="pw-strength-bar-fill" id="pwStrengthFill"></div></div>
        <div class="pw-strength-row">
          <span class="pw-strength-label" id="pwStrengthLabel"></span>
          <button type="button" class="pw-suggest-btn" onclick="suggestStrongPassword()">Suggest strong password</button>
        </div>
        <div class="pw-requirements" id="pwRequirements">
          <span class="pw-req" id="pwReqLen"><span class="pw-req-icon">○</span> 8+ chars</span>
          <span class="pw-req" id="pwReqUpper"><span class="pw-req-icon">○</span> Uppercase</span>
          <span class="pw-req" id="pwReqLower"><span class="pw-req-icon">○</span> Lowercase</span>
          <span class="pw-req" id="pwReqNum"><span class="pw-req-icon">○</span> Number</span>
          <span class="pw-req" id="pwReqSpecial"><span class="pw-req-icon">○</span> Special char</span>
        </div>
      </div>
      <div class="remember-row">
        <label class="remember-label"><input type="checkbox" id="rememberMe" checked> Remember me</label>
        <a href="https://jemhr.1password.com/home?a=new" target="_blank" rel="noopener" class="forgot-password-link">Forgot password?</a>
      </div>
      <div class="welcome-error" id="welcomeError">Please enter your @jemhr.com email and password to begin.</div>
    </form>
    <button class="start-btn" id="startBtn" onclick="startOnboarding()" disabled>
      Begin Onboarding →
    </button>
  </div>
</div>

<!-- ═══════════ MAIN APP ═══════════ -->
<div class="app-container" id="app">
