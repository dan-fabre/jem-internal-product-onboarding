}

function saveLockedAnswers() {
  var key = getLockedAnswersKey();
  if (!key) return;
  try {
    var data = {};
    for (var k in lockedAnswers) { data[k] = lockedAnswers[k]; }
    var setArr = [];
    answeredQuizzes.forEach(function(v) { setArr.push(v); });
    localStorage.setItem(key, JSON.stringify({ answers: data, answered: setArr, score: quizScore }));
  } catch(e) {}
}

function restoreLockedAnswers() {
  var key = getLockedAnswersKey();
  if (!key) return;
  try {
    var raw = localStorage.getItem(key);
    if (!raw) return;
    var parsed = JSON.parse(raw);
    if (parsed.answers) lockedAnswers = parsed.answers;
    if (parsed.answered) {
      parsed.answered.forEach(function(v) { answeredQuizzes.add(v); });
    }
    if (typeof parsed.score === 'number') quizScore = parsed.score;
  } catch(e) {}
}

