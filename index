<!-- 1Password Save Toast -->
<div class="onepass-toast" id="onepassToast">
  <button class="onepass-toast-close" onclick="dismissOnePassToast()">&times;</button>
  <div class="onepass-toast-icon">🔑</div>
  <div class="onepass-toast-body">
    <div class="onepass-toast-title">Save to 1Password?</div>
