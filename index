  /* ─── 1Password Save Toast ─── */
  .onepass-toast {
    position: fixed;
    bottom: 32px;
    right: 32px;
    background: white;
    border-radius: 16px;
    padding: 20px 24px;
    box-shadow: 0 12px 48px rgba(0,0,0,0.15), 0 0 0 1px rgba(0,0,0,0.05);
