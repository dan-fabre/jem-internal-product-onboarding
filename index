function saveOnboardingUrl() {
  var input = document.getElementById('onboardingUrlInput');
  if (!input) return;
  var url = input.value.trim();
  if (url && !url.match(/^https?:\/\/.+/)) {
    alert('Please enter a valid URL starting with http:// or https://');
    return;
  }
  try { localStorage.setItem('jem_onboarding_url', url); } catch(e) {}
  renderSettings();
}

function clearOnboardingUrl() {
  try { localStorage.removeItem('jem_onboarding_url'); } catch(e) {}
  renderSettings();
}

function getOnboardingUrl() {
  var saved = '';
  try { saved = localStorage.getItem('jem_onboarding_url') || ''; } catch(e) {}
  return saved || window.location.href.split('?')[0].split('#')[0];
}

function revokeInvite(email) {
  if (!isCurrentUserSuperUser()) return;
  var invites = getPendingInvites();
  invites = invites.filter(function(inv) { return inv.email !== email; });
  savePendingInvites(invites);
  // Also remove from admins if they were invited as admin
  var admins = getAdminEmails();
  var idx = admins.indexOf(email.toLowerCase());
  if (idx >= 0) { admins.splice(idx, 1); setAdminEmails(admins); }
  renderSettings();
}

