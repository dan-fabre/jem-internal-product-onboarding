<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jem HR — Product Onboarding</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --jem-red: #F27B8A;
    --jem-red-dark: #E0606F;
    --jem-dark: #1a1a2e;
    --jem-navy: #16213e;
    --jem-accent: #0f3460;
    --jem-light: #f8f9fc;
    --jem-gray: #6b7280;
    --jem-green: #10b981;
    --jem-blue: #3b82f6;
    --jem-purple: #8b5cf6;
    --jem-orange: #f59e0b;
    --sidebar-width: 300px;
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    background: var(--jem-light);
    color: #1f2937;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ─── Welcome Screen ─── */
  .welcome-screen {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--jem-dark) 0%, var(--jem-navy) 40%, var(--jem-accent) 100%);
    position: relative;
    overflow: hidden;
  }

  .welcome-screen::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at 30% 50%, rgba(242, 123, 138, 0.08) 0%, transparent 50%),
                radial-gradient(circle at 70% 80%, rgba(59, 130, 246, 0.06) 0%, transparent 50%);
    animation: float 20s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(30px, -30px) rotate(1deg); }
    66% { transform: translate(-20px, 20px) rotate(-1deg); }
  }

  .welcome-content {
    text-align: center;
    position: relative;
    z-index: 1;
    max-width: 700px;
    padding: 40px;
  }

  .jem-logo {
    width: 140px;
    height: 72px;
    background: var(--jem-red);
    border-radius: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 32px;
    font-size: 38px;
    font-weight: 800;
    color: white;
    letter-spacing: -0.5px;
    box-shadow: 0 20px 60px rgba(242, 123, 138, 0.3);
    animation: pulse-glow 3s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 20px 60px rgba(242, 123, 138, 0.3); }
    50% { box-shadow: 0 20px 80px rgba(242, 123, 138, 0.5); }
  }

  .welcome-content h1 {
    font-size: 48px;
    font-weight: 800;
    color: white;
    margin-bottom: 16px;
    line-height: 1.1;
  }

  .welcome-content h1 span { color: var(--jem-red); }

  .welcome-content p {
    font-size: 18px;
    color: rgba(255,255,255,0.7);
    margin-bottom: 40px;
    line-height: 1.7;
  }

  .welcome-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 380px;
    margin: 0 auto 32px;
    animation: fadeInUp 0.5s ease 0.3s both;
  }
  .welcome-input {
    padding: 14px 18px;
    border: 2px solid rgba(255,255,255,0.15);
    border-radius: 12px;
    background: rgba(255,255,255,0.08);
    color: white;
    font-size: 15px;
    font-family: inherit;
    outline: none;
    transition: var(--transition);
  }
  .welcome-input::placeholder { color: rgba(255,255,255,0.4); }
  .welcome-input:focus { border-color: var(--jem-red); background: rgba(255,255,255,0.12); }
  .welcome-input.error { border-color: #f87171; }
  .password-field-wrap {
    position: relative;
  }
  .password-field-wrap .welcome-input {
    width: 100%;
    padding-right: 48px;
  }
  .password-toggle {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    opacity: 0.5;
    transition: opacity 0.2s ease;
    padding: 4px;
  }
  .password-toggle:hover { opacity: 0.8; }

  .remember-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: -4px;
  }
  .remember-label {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    display: flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    user-select: none;
    transition: color 0.2s ease;
  }
  .remember-label:hover { color: rgba(255,255,255,0.7); }
  .remember-label input[type="checkbox"] {
    width: 15px;
    height: 15px;
    accent-color: var(--jem-red);
    cursor: pointer;
  }
  .forgot-password-link {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .forgot-password-link:hover { color: var(--jem-red); }

  /* Password Strength Meter */
  .pw-strength-wrap {
    margin-top: -2px;
    margin-bottom: 4px;
  }
  .pw-strength-bar-track {
    height: 4px;
    background: rgba(255,255,255,0.1);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 6px;
  }
  .pw-strength-bar-fill {
    height: 100%;
    width: 0%;
    border-radius: 4px;
    transition: width 0.4s ease, background 0.4s ease;
  }
  .pw-strength-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 20px;
  }
  .pw-strength-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3px;
    transition: color 0.3s ease;
    color: rgba(255,255,255,0.4);
  }
  .pw-suggest-btn {
    font-size: 11px;
    font-weight: 600;
    color: var(--jem-red);
    background: rgba(242, 123, 138, 0.1);
    border: 1px solid rgba(242, 123, 138, 0.25);
    border-radius: 6px;
    padding: 3px 10px;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
  }
  .pw-suggest-btn:hover {
    background: rgba(242, 123, 138, 0.2);
    border-color: rgba(242, 123, 138, 0.4);
  }
  .pw-requirements {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 10px;
    margin-top: 4px;
  }
  .pw-req {
    font-size: 10px;
    color: rgba(255,255,255,0.3);
    display: flex;
    align-items: center;
    gap: 4px;
    transition: color 0.3s ease;
  }
  .pw-req.met { color: #10b981; }
  .pw-req-icon {
    font-size: 10px;
    width: 14px;
    text-align: center;
  }

  .welcome-error {
    color: #f87171;
    font-size: 13px;
    text-align: center;
    display: none;
  }
  .welcome-error.show { display: block; }

  .start-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 18px 42px;
    background: var(--jem-red);
    color: white;
    border: none;
    border-radius: 14px;
    font-size: 18px;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition);
    box-shadow: 0 8px 30px rgba(242, 123, 138, 0.4);
  }

  .start-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(242, 123, 138, 0.5);
    background: var(--jem-red-dark);
  }
  .start-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  /* ─── Main Layout ─── */
  .app-container { display: none; min-height: 100vh; }
  .app-container.active { display: flex; }

  /* ─── Sidebar ─── */
  .sidebar {
    width: var(--sidebar-width);
    background: white;
    border-right: 1px solid #e5e7eb;
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    z-index: 100;
    overflow-y: auto;
  }

  .sidebar-header {
    padding: 24px;
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .sidebar-logo {
    width: 56px;
    height: 30px;
    background: var(--jem-red);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 800;
    color: white;
    letter-spacing: -0.3px;
    flex-shrink: 0;
  }

  .sidebar-title { font-size: 15px; font-weight: 700; color: var(--jem-dark); }
  .sidebar-subtitle { font-size: 11px; color: var(--jem-gray); font-weight: 500; }

  .sidebar-progress {
    padding: 20px 24px;
    border-bottom: 1px solid #e5e7eb;
  }

  .progress-label {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    font-size: 12px;
    font-weight: 600;
    color: var(--jem-gray);
  }

  .progress-bar {
    height: 6px;
    background: #e5e7eb;
    border-radius: 3px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--jem-red), var(--jem-blue));
    border-radius: 3px;
    transition: width 0.5s ease;
  }

  .sidebar-nav { padding: 16px 12px; flex: 1; }

  .nav-section-label {
    padding: 8px 12px 6px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: #9ca3af;
  }
  .nav-section-label.collapsible {
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.15s ease;
    user-select: none;
  }
  .nav-section-label.collapsible:hover {
    color: var(--jem-dark);
    background: #f3f4f6;
  }
  .nav-section-chevron {
    font-size: 10px;
    transition: transform 0.25s ease;
  }
  .nav-section-label.collapsed .nav-section-chevron {
    transform: rotate(-90deg);
  }
  .nav-section-group {
    overflow: hidden;
    max-height: 500px;
    transition: max-height 0.35s ease, opacity 0.25s ease;
    opacity: 1;
  }
  .nav-section-group.collapsed {
    max-height: 0;
    opacity: 0;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 10px;
    cursor: pointer;
    transition: var(--transition);
    font-size: 13.5px;
    font-weight: 500;
    color: #4b5563;
    margin-bottom: 2px;
    position: relative;
  }

  .nav-item:hover { background: #f3f4f6; color: var(--jem-dark); }

  .nav-item.active {
    background: rgba(242, 123, 138, 0.08);
    color: var(--jem-red);
    font-weight: 600;
  }

  .nav-item.completed {
    color: var(--jem-green);
  }
  .nav-item.completed::after {
    content: '✓';
    position: absolute;
    right: 12px;
    font-size: 12px;
    color: var(--jem-green);
    font-weight: 700;
  }
  .nav-item.completed:hover {
    background: rgba(16, 185, 129, 0.06);
  }

  .nav-item.locked { opacity: 0.4; cursor: not-allowed; }

  /* ─── Sidebar User Footer ─── */
  .sidebar-user-footer {
    padding: 14px 20px;
    border-top: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #fafafa;
  }
  .sidebar-user-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--jem-red);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .sidebar-user-info {
    flex: 1;
    min-width: 0;
  }
  .sidebar-user-name {
    font-size: 12px;
    font-weight: 600;
    color: var(--jem-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sidebar-user-email {
    font-size: 10px;
    color: #9ca3af;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .sidebar-user-role {
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 7px;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .sidebar-user-role.admin {
    background: rgba(139, 92, 246, 0.1);
    color: var(--jem-purple);
  }
  .sidebar-user-role.trainee {
    background: rgba(107, 114, 128, 0.1);
    color: var(--jem-gray);
  }
  .sidebar-user-role.super {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.15), rgba(242, 123, 138, 0.15));
    color: #f59e0b;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .nav-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-size: 16px;
    flex-shrink: 0;
  }

  /* ─── Main Content ─── */
  .main-content {
    margin-left: var(--sidebar-width);
    flex: 1;
    min-height: 100vh;
  }

  .top-bar {
    height: 64px;
    background: white;
    border-bottom: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .top-bar-left { display: flex; align-items: center; gap: 16px; }

  .breadcrumb {
    font-size: 13px;
    color: var(--jem-gray);
  }
  .breadcrumb span { color: var(--jem-dark); font-weight: 600; }

  .step-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(242, 123, 138, 0.08);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    color: var(--jem-red);
  }

  .page-content {
    padding: 32px;
    max-width: 1000px;
    margin: 0 auto;
    animation: fadeInUp 0.35s ease;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── Module Content Cards ─── */
  .module-header {
    margin-bottom: 20px;
  }

  .module-header h2 {
    font-size: 28px;
    font-weight: 800;
    color: var(--jem-dark);
    margin-bottom: 8px;
  }

  .module-header p {
    font-size: 15px;
    color: var(--jem-gray);
    line-height: 1.6;
  }

  .module-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .tag-essential { background: rgba(242, 123, 138, 0.1); color: var(--jem-red); }
  .tag-dashboard { background: rgba(59, 130, 246, 0.1); color: var(--jem-blue); }
  .tag-admin { background: rgba(139, 92, 246, 0.1); color: var(--jem-purple); }
  .tag-feature { background: rgba(16, 185, 129, 0.1); color: var(--jem-green); }

  .content-card {
    background: white;
    border-radius: 16px;
    padding: 28px;
    margin-bottom: 20px;
    border: 1px solid #e5e7eb;
    transition: var(--transition);
  }

  .content-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    transform: translateY(-1px);
  }

  .content-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--jem-dark);
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    user-select: none;
    transition: color 0.2s ease;
  }
  .content-card h3:hover { color: var(--jem-red); }

  .content-card h3 .toggle-chevron {
    margin-left: auto;
    font-size: 14px;
    color: #9ca3af;
    transition: transform 0.3s ease, color 0.2s ease;
    flex-shrink: 0;
  }
  .content-card h3:hover .toggle-chevron { color: var(--jem-red); }
  .content-card.collapsed h3 .toggle-chevron { transform: rotate(-90deg); }

  .content-card-body {
    overflow: hidden;
    max-height: 2000px;
    transition: max-height 0.4s ease, opacity 0.3s ease;
    opacity: 1;
  }
  .content-card.collapsed .content-card-body {
    max-height: 0;
    opacity: 0;
  }
  .content-card.collapsed {
    padding-bottom: 4px;
  }
  .content-card.collapsed h3 {
    margin-bottom: 0;
  }

  .content-card p, .content-card li {
    font-size: 14px;
    color: #4b5563;
    line-height: 1.7;
  }

  .content-card ul {
    margin: 12px 0;
    padding-left: 20px;
  }

  .content-card li { margin-bottom: 8px; }

  .step-list {
    list-style: none;
    padding: 0;
    counter-reset: steps;
  }

  .step-list li {
    counter-increment: steps;
    padding: 14px 14px 14px 56px;
    position: relative;
    background: var(--jem-light);
    border-radius: 10px;
    margin-bottom: 8px;
    font-size: 14px;
  }

  .step-list li::before {
    content: counter(steps);
    position: absolute;
    left: 14px;
    top: 14px;
    width: 28px;
    height: 28px;
    background: var(--jem-red);
    color: white;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
  }

  .info-callout {
    background: rgba(59, 130, 246, 0.06);
    border-left: 4px solid var(--jem-blue);
    padding: 16px 20px;
    border-radius: 0 10px 10px 0;
    margin: 16px 0;
    font-size: 13.5px;
    color: #374151;
    line-height: 1.6;
  }

  .warning-callout {
    background: rgba(245, 158, 11, 0.06);
    border-left: 4px solid var(--jem-orange);
    padding: 16px 20px;
    border-radius: 0 10px 10px 0;
    margin: 16px 0;
    font-size: 13.5px;
    color: #374151;
    line-height: 1.6;
  }

  .tip-callout {
    background: rgba(16, 185, 129, 0.06);
    border-left: 4px solid var(--jem-green);
    padding: 16px 20px;
    border-radius: 0 10px 10px 0;
    margin: 16px 0;
    font-size: 13.5px;
    color: #374151;
    line-height: 1.6;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin: 12px 0 16px;
  }

  .feature-item {
    background: var(--jem-light);
    padding: 20px;
    border-radius: 12px;
    text-align: center;
    transition: var(--transition);
  }

  .feature-item:hover { transform: translateY(-2px); box-shadow: 0 4px 15px rgba(0,0,0,0.06); }

  .feature-icon {
    font-size: 28px;
    margin-bottom: 10px;
  }

  .feature-item h4 {
    font-size: 14px;
    font-weight: 700;
    color: var(--jem-dark);
    margin-bottom: 6px;
  }

  .feature-item p {
    font-size: 12px;
    color: var(--jem-gray);
    line-height: 1.5;
  }

  /* ─── Quiz ─── */
  .quiz-section {
    background: linear-gradient(135deg, var(--jem-dark), var(--jem-navy));
    border-radius: 16px;
    padding: 28px;
    margin: 24px 0;
    color: white;
  }

  .quiz-section h3 {
    color: white;
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .quiz-question {
    font-size: 15px;
    margin-bottom: 16px;
    line-height: 1.6;
  }

  .quiz-options { display: flex; flex-direction: column; gap: 8px; }

  .quiz-option {
    padding: 12px 16px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 10px;
    cursor: pointer;
    transition: var(--transition);
    font-size: 14px;
    color: rgba(255,255,255,0.9);
  }

  .quiz-option:hover { background: rgba(255,255,255,0.14); }
  .quiz-option.correct {
    background: rgba(16, 185, 129, 0.3);
    border-color: var(--jem-green);
    color: white;
  }
  .quiz-option.incorrect {
    background: rgba(239, 68, 68, 0.3);
    border-color: #ef4444;
    color: white;
  }

  .quiz-feedback {
    margin-top: 12px;
    padding: 12px 16px;
    border-radius: 10px;
    font-size: 13px;
    display: none;
  }

  .quiz-feedback.show { display: block; }
  .quiz-feedback.correct-feedback { background: rgba(16, 185, 129, 0.2); color: #86efac; }
  .quiz-feedback.incorrect-feedback { background: rgba(239, 68, 68, 0.2); color: #fca5a5; }

  /* ─── Quiz Lock Badge ─── */
  .quiz-locked-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    padding: 8px 16px;
    background: rgba(245, 158, 11, 0.12);
    border: 1px solid rgba(245, 158, 11, 0.25);
    border-radius: 8px;
    font-size: 12px;
    font-weight: 700;
    color: #f59e0b;
    letter-spacing: 0.3px;
    animation: lock-fade-in 0.5s ease both;
  }
  .quiz-locked-badge .lock-icon {
