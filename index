function downloadCertificate() {
  const canvas = document.createElement('canvas');
  const W = 1600;
  const H = 1132; // ~A4 landscape ratio
  canvas.width = W;
  canvas.height = H;
  const ctx = canvas.getContext('2d');

  // Background
  ctx.fillStyle = '#ffffff';
  ctx.fillRect(0, 0, W, H);

  // Outer border (double line)
  ctx.strokeStyle = '#F27B8A';
  ctx.lineWidth = 6;
  ctx.strokeRect(30, 30, W - 60, H - 60);
  ctx.strokeStyle = '#1a1a2e';
  ctx.lineWidth = 2;
  ctx.strokeRect(45, 45, W - 90, H - 90);

  // Corner accents
  const cornerSize = 60;
  const corners = [[50, 50], [W - 50, 50], [50, H - 50], [W - 50, H - 50]];
  ctx.fillStyle = '#F27B8A';
  corners.forEach(([cx, cy]) => {
    ctx.beginPath();
    ctx.arc(cx, cy, 8, 0, Math.PI * 2);
    ctx.fill();
  });

  // Top decorative line
  const grad1 = ctx.createLinearGradient(200, 0, W - 200, 0);
  grad1.addColorStop(0, '#F27B8A');
  grad1.addColorStop(0.5, '#8b5cf6');
  grad1.addColorStop(1, '#3b82f6');
  ctx.strokeStyle = grad1;
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.moveTo(200, 120);
  ctx.lineTo(W - 200, 120);
  ctx.stroke();

  // Jem logo badge (pill shape)
  ctx.fillStyle = '#F27B8A';
  roundRect(ctx, W / 2 - 56, 88, 112, 56, 28);
  ctx.fill();
  ctx.fillStyle = '#ffffff';
  ctx.font = 'bold 26px Inter, Arial, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('jem', W / 2, 124);

  // "CERTIFICATE OF COMPLETION" title
  ctx.fillStyle = '#1a1a2e';
  ctx.font = '300 18px Inter, Arial, sans-serif';
  ctx.textAlign = 'center';
  ctx.letterSpacing = '8px';
  ctx.fillText('C E R T I F I C A T E   O F   C O M P L E T I O N', W / 2, 210);

  // Subtitle
  ctx.fillStyle = '#6b7280';
  ctx.font = '400 15px Inter, Arial, sans-serif';
  ctx.fillText('This is to certify that', W / 2, 280);

  // Trainee name (large, elegant)
  ctx.fillStyle = '#1a1a2e';
  ctx.font = 'bold 52px Inter, Arial, sans-serif';
  ctx.fillText(currentTrainee.name, W / 2, 350);

  // Decorative line under name
  const nameWidth = ctx.measureText(currentTrainee.name).width;
  ctx.strokeStyle = '#F27B8A';
  ctx.lineWidth = 2;
  ctx.beginPath();
  ctx.moveTo(W / 2 - nameWidth / 2 - 20, 370);
  ctx.lineTo(W / 2 + nameWidth / 2 + 20, 370);
  ctx.stroke();

  // "has successfully completed"
  ctx.fillStyle = '#6b7280';
  ctx.font = '400 16px Inter, Arial, sans-serif';
  ctx.fillText('has successfully completed the', W / 2, 420);

  // Course title
  ctx.fillStyle = '#1a1a2e';
  ctx.font = 'bold 30px Inter, Arial, sans-serif';
  ctx.fillText('Jem HR Product Onboarding', W / 2, 470);

  // Module count + quiz score
  ctx.fillStyle = '#6b7280';
  ctx.font = '400 15px Inter, Arial, sans-serif';
  ctx.fillText(modules.length + ' modules completed  •  Quiz score: ' + quizScore + '/' + totalQuizzes, W / 2, 520);

  // Covering
  ctx.font = '400 14px Inter, Arial, sans-serif';
  ctx.fillText('Covering the Jem Dashboard, Admin Portal, and WhatsApp Chatbot', W / 2, 555);

  // Bottom decorative line
  ctx.strokeStyle = grad1;
  ctx.lineWidth = 3;
  ctx.beginPath();
  ctx.moveTo(200, H - 120);
  ctx.lineTo(W - 200, H - 120);
  ctx.stroke();

  // Date
  const dateStr = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
  ctx.fillStyle = '#1a1a2e';
  ctx.font = '500 14px Inter, Arial, sans-serif';

  // Date section (left)
  ctx.textAlign = 'center';
  ctx.fillText(dateStr, W * 0.25, H - 80);
  ctx.strokeStyle = '#d1d5db';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(W * 0.25 - 80, H - 65);
  ctx.lineTo(W * 0.25 + 80, H - 65);
  ctx.stroke();
  ctx.fillStyle = '#9ca3af';
  ctx.font = '400 11px Inter, Arial, sans-serif';
  ctx.fillText('DATE OF COMPLETION', W * 0.25, H - 50);

  // Certificate ID (center)
  ctx.fillStyle = '#1a1a2e';
  ctx.font = '500 14px Inter, Arial, sans-serif';
  const certId = 'JEM-' + Date.now().toString(36).toUpperCase().slice(-6);
  ctx.fillText(certId, W * 0.5, H - 80);
  ctx.strokeStyle = '#d1d5db';
  ctx.beginPath();
  ctx.moveTo(W * 0.5 - 60, H - 65);
  ctx.lineTo(W * 0.5 + 60, H - 65);
  ctx.stroke();
  ctx.fillStyle = '#9ca3af';
  ctx.font = '400 11px Inter, Arial, sans-serif';
  ctx.fillText('CERTIFICATE ID', W * 0.5, H - 50);

  // Issuer (right)
  ctx.fillStyle = '#1a1a2e';
  ctx.font = '500 14px Inter, Arial, sans-serif';
  ctx.fillText('Jem HR', W * 0.75, H - 80);
  ctx.strokeStyle = '#d1d5db';
  ctx.beginPath();
  ctx.moveTo(W * 0.75 - 60, H - 65);
  ctx.lineTo(W * 0.75 + 60, H - 65);
  ctx.stroke();
  ctx.fillStyle = '#9ca3af';
  ctx.font = '400 11px Inter, Arial, sans-serif';
  ctx.fillText('ISSUED BY', W * 0.75, H - 50);

  // Watermark
  ctx.save();
  ctx.translate(W / 2, H / 2 + 20);
  ctx.rotate(-0.15);
  ctx.fillStyle = 'rgba(242, 123, 138, 0.04)';
  ctx.font = 'bold 160px Inter, Arial, sans-serif';
  ctx.textAlign = 'center';
  ctx.fillText('jem', 0, 0);
  ctx.restore();

  // Download as PDF-like image (high quality PNG)
  canvas.toBlob(function(blob) {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'Jem HR Certificate - ' + currentTrainee.name + '.png';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }, 'image/png');
}

// Rounded rect helper for canvas
function roundRect(ctx, x, y, w, h, r) {
  ctx.beginPath();
  ctx.moveTo(x + r, y);
  ctx.lineTo(x + w - r, y);
  ctx.quadraticCurveTo(x + w, y, x + w, y + r);
  ctx.lineTo(x + w, y + h - r);
  ctx.quadraticCurveTo(x + w, y + h, x + w - r, y + h);
  ctx.lineTo(x + r, y + h);
  ctx.quadraticCurveTo(x, y + h, x, y + h - r);
  ctx.lineTo(x, y + r);
  ctx.quadraticCurveTo(x, y, x + r, y);
  ctx.closePath();
}

// ═══════════ VIDEO UPLOAD MANAGEMENT ═══════════
var VIDEO_STORAGE_KEY = 'jem_onboarding_videos';

function getSavedVideos() {
  try { return JSON.parse(localStorage.getItem(VIDEO_STORAGE_KEY) || '{}'); } catch(e) { return {}; }
}

function saveVideo(slotId, url) {
  var vids = getSavedVideos();
  vids[slotId] = url;
  localStorage.setItem(VIDEO_STORAGE_KEY, JSON.stringify(vids));
}

function removeVideo(slotId) {
  var vids = getSavedVideos();
  delete vids[slotId];
  localStorage.setItem(VIDEO_STORAGE_KEY, JSON.stringify(vids));
}

function parseVideoUrl(url) {
  url = url.trim();
  // YouTube
  var yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([\w-]+)/);
  if (yt) return 'https://www.youtube.com/embed/' + yt[1];
  // Loom
  var loom = url.match(/loom\.com\/(?:share|embed)\/([\w]+)/);
  if (loom) return 'https://www.loom.com/embed/' + loom[1];
  // Vimeo
  var vim = url.match(/vimeo\.com\/(?:video\/)?(\d+)/);
  if (vim) return 'https://player.vimeo.com/video/' + vim[1];
  // Already an embed URL or other iframe-compatible URL
  if (url.startsWith('http')) return url;
  return null;
}

function embedVideoUrl(slotId) {
  var input = document.getElementById('videoUrl_' + slotId);
  if (!input) return;
  var raw = input.value.trim();
  if (!raw) { input.style.borderColor = '#f87171'; return; }
  var embedUrl = parseVideoUrl(raw);
  if (!embedUrl) {
    input.style.borderColor = '#f87171';
    alert('Could not parse video URL. Please use a YouTube, Loom, or Vimeo link.');
    return;
  }
  saveVideo(slotId, embedUrl);
  renderModule(currentModule);
}

function removeVideoEmbed(slotId) {
  if (!confirm('Remove this video?')) return;
  removeVideo(slotId);
  renderModule(currentModule);
}

function handleVideoFile(slotId, fileInput) {
  var file = fileInput.files[0];
  if (!file) return;
  if (!file.type.startsWith('video/')) {
    alert('Please select a video file (MP4, WebM, etc.)');
    return;
  }
  if (file.size > 100 * 1024 * 1024) {
    alert('File is too large. Please use a file under 100MB or paste a video URL instead.');
    return;
  }
  var url = URL.createObjectURL(file);
  saveVideo(slotId, 'blob:' + file.name);

  var wrapper = fileInput.closest('.video-section').querySelector('.video-wrapper');
  wrapper.innerHTML = '<video controls style="position:absolute;top:0;left:0;width:100%;height:100%;border-radius:12px;background:#000"><source src="' + url + '" type="' + file.type + '">Your browser does not support video.</video>';

  var uploadArea = fileInput.closest('.video-section').querySelector('.video-upload-area');
  if (uploadArea) {
    uploadArea.innerHTML = '<button class="video-remove-btn" onclick="removeVideoEmbed(\'' + slotId + '\')">✕ Remove video</button>' +
      '<span style="font-size:11px;color:#9ca3af">📁 ' + file.name + '</span>';
  }
}

function initVideoUploads(moduleIndex) {
  var savedVids = getSavedVideos();
  var sections = document.querySelectorAll('.video-section');

  sections.forEach(function(section, i) {
    var slotId = 'mod' + moduleIndex + '_vid' + i;
    var wrapper = section.querySelector('.video-wrapper');
    var placeholder = section.querySelector('.video-placeholder');
    var savedUrl = savedVids[slotId];

    // If there's a saved embed URL, replace placeholder with iframe
    if (savedUrl && !savedUrl.startsWith('blob:')) {
      if (placeholder) {
        placeholder.style.display = 'none';
      }
      var iframe = document.createElement('iframe');
      iframe.src = savedUrl;
      iframe.allowFullscreen = true;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;border:none;border-radius:12px';
      wrapper.appendChild(iframe);
    }

    // Add upload area below video (admin only)
    if (isCurrentUserAdmin()) {
      var uploadArea = document.createElement('div');
      uploadArea.className = 'video-upload-area';

      if (savedUrl && !savedUrl.startsWith('blob:')) {
        uploadArea.innerHTML =
          '<button class="video-remove-btn" onclick="removeVideoEmbed(\'' + slotId + '\')">✕ Remove video</button>' +
          '<span style="font-size:11px;color:var(--jem-green);font-weight:500">✓ Video embedded</span>';
      } else if (!savedUrl) {
        uploadArea.innerHTML =
          '<button class="video-upload-btn" onclick="document.getElementById(\'fileInput_' + slotId + '\').click()">📁 Upload file</button>' +
          '<input type="file" id="fileInput_' + slotId + '" accept="video/*" style="display:none" onchange="handleVideoFile(\'' + slotId + '\', this)">' +
          '<span style="color:#d1d5db;font-size:12px">or</span>' +
          '<input type="text" class="video-url-input" id="videoUrl_' + slotId + '" placeholder="Paste YouTube, Loom, or Vimeo URL...">' +
          '<button class="video-embed-btn" onclick="embedVideoUrl(\'' + slotId + '\')">Embed</button>' +
          '<div class="video-upload-hint">Supports YouTube, Loom, Vimeo links or direct video file upload (MP4, WebM — max 100MB)</div>';
