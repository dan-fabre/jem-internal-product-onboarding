// ═══════════ ACTIVITY LOG ═══════════
function logModuleVisit(index) {
  const entry = activityLog[index];
  const now = new Date();
  entry.lastVisitedAt = now;
  entry.visitCount++;
  if (entry.status === 'not-started') {
    entry.status = 'started';
    entry.startedAt = now;
  }
  if (entry.status === 'started' && entry.visitCount > 1) {
    entry.status = 'in-progress';
  }
}

function logModuleComplete(index) {
  const entry = activityLog[index];
  if (entry.status !== 'completed') {
    entry.status = 'completed';
    entry.completedAt = new Date();
    // Add final time
    if (moduleEnteredAt && index === currentModule) {
      entry.timeSpentMs += Date.now() - moduleEnteredAt;
    }
  }
}

function formatTime(ms) {
  if (!ms || ms < 1000) return '< 1s';
  const secs = Math.floor(ms / 1000);
  if (secs < 60) return secs + 's';
  const mins = Math.floor(secs / 60);
  const remainSecs = secs % 60;
  if (mins < 60) return mins + 'm ' + remainSecs + 's';
  const hrs = Math.floor(mins / 60);
  return hrs + 'h ' + (mins % 60) + 'm';
}

function formatTimestamp(date) {
  if (!date) return '-';
  return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) +
    ', ' + date.toLocaleDateString([], { day: 'numeric', month: 'short' });
}

function getOverallStatus() {
  const completed = activityLog.filter(e => e.status === 'completed').length;
  const started = activityLog.filter(e => e.status !== 'not-started').length;
  if (completed === activityLog.length) return 'completed';
  if (started > 0) return 'in-progress';
  return 'not-started';
}

