  if (!raw) {
    msgEl.className = 'invite-msg error';
    msgEl.textContent = 'Please enter at least one email address.';
    return;
  }

  // Parse comma/space/newline separated emails
  const emails = raw.split(/[,\s\n]+/).map(e => e.trim().toLowerCase()).filter(e => e);
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const invalid = emails.filter(e => !emailRegex.test(e));

  if (invalid.length > 0) {
    msgEl.className = 'invite-msg error';
    msgEl.textContent = 'Invalid email' + (invalid.length > 1 ? 's' : '') + ': ' + invalid.join(', ');
    return;
  }

  // Enforce @jemhr.com domain
  const nonJem = emails.filter(e => !e.endsWith('@jemhr.com'));
  if (nonJem.length > 0) {
    msgEl.className = 'invite-msg error';
    msgEl.textContent = 'Only @jemhr.com emails allowed: ' + nonJem.join(', ');
    return;
  }

  // Build Gmail compose URL
  var senderName = currentTrainee.name || 'Jem HR';
  var roleLabel = role === 'admin' ? 'Admin' : 'Trainee';
  var teamLabel = team ? ' (' + team.charAt(0).toUpperCase() + team.slice(1) + ' team)' : '';
  var subject = encodeURIComponent('You\'re Invited to Jem HR Product Onboarding');
  var toolLink = getOnboardingUrl();
  var body = encodeURIComponent(
    'Hi there,\n\n' +
    'You have been invited by ' + senderName + ' to join the Jem HR Product Onboarding platform as a ' + roleLabel + teamLabel + '.\n\n' +
    'Open the onboarding tool here:\n' +
    toolLink + '\n\n' +
    'To get started:\n' +
    '1. Click the link above to open the Jem HR Onboarding tool\n' +
    '2. Enter your name and your @jemhr.com email address\n' +
    '3. Create a password and begin your training\n\n' +
    'The onboarding covers everything you need to know about Jem HR\'s products, from leave management to WhatsApp integration.\n\n' +
    'If you have any questions, reach out to ' + senderName + ' at ' + currentTrainee.email + '.\n\n' +
    'Welcome to the team!\n' +
    '— Jem HR Onboarding'
  );
  var to = encodeURIComponent(emails.join(','));
  var gmailUrl = 'https://mail.google.com/mail/?view=cm&fs=1&to=' + to + '&su=' + subject + '&body=' + body;

  // Open Gmail compose
  window.open(gmailUrl, '_blank', 'noopener');

  // Store data for confirmation
  _pendingInviteData = { emails: emails, role: role, team: team, roleLabel: roleLabel };

  // Show confirmation prompt — don't save yet
  msgEl.className = '';
  msgEl.textContent = '';
  textarea.value = '';

  var confirmHtml = '<div class="invite-confirm-box" id="inviteConfirmBox">' +
    '<div class="invite-confirm-text">Did you send the email in Gmail?</div>' +
    '<div class="invite-confirm-sub">The invite will only be recorded after you confirm it was sent.</div>' +
    '<div class="invite-confirm-btns">' +
      '<button class="invite-confirm-yes" onclick="confirmInviteSent()">Yes, I sent it</button>' +
      '<button class="invite-confirm-no" onclick="cancelInviteSent()">No, I didn\'t send it</button>' +
    '</div>' +
  '</div>';

  msgEl.insertAdjacentHTML('afterend', confirmHtml);
}

function confirmInviteSent() {
  if (!_pendingInviteData) return;

  var data = _pendingInviteData;
  _pendingInviteData = null;

  // Now save to admins list if role is admin
  var admins = getAdminEmails();
  var added = 0;
  var alreadyAdmin = 0;

  data.emails.forEach(function(email) {
    if (data.role === 'admin') {
      if (!admins.includes(email)) {
        admins.push(email);
        added++;
      } else {
        alreadyAdmin++;
      }
    } else {
      added++;
    }
  });

  setAdminEmails(admins);

  // Now save to pending invites
  var pendingInvites = getPendingInvites();
  var now = new Date().toISOString();
  data.emails.forEach(function(email) {
    var exists = pendingInvites.find(function(inv) { return inv.email === email; });
    if (!exists) {
      pendingInvites.push({ email: email, role: data.role, team: data.team, sentAt: now, sentBy: currentTrainee.email });
    }
  });
  savePendingInvites(pendingInvites);

  // Show success
  var msgEl = document.getElementById('inviteMsg');
  var confirmBox = document.getElementById('inviteConfirmBox');
  if (confirmBox) confirmBox.remove();

  var msg = added + ' invite' + (added > 1 ? 's' : '') + ' confirmed and saved as ' + data.roleLabel + '.';
  if (alreadyAdmin > 0) msg += ' ' + alreadyAdmin + ' already admin.';

  msgEl.className = 'invite-msg success';
  msgEl.textContent = msg;

  // Re-render to show in sent list
  setTimeout(function() { renderSettings(); buildSidebar(); }, 1500);
}

function cancelInviteSent() {
  _pendingInviteData = null;

  var confirmBox = document.getElementById('inviteConfirmBox');
  if (confirmBox) confirmBox.remove();

  var msgEl = document.getElementById('inviteMsg');
  msgEl.className = 'invite-msg error';
  msgEl.textContent = 'Invite not recorded. No email was sent.';

  setTimeout(function() { msgEl.textContent = ''; msgEl.className = ''; }, 3000);
}

// On first ever load, if no admins exist yet, make the first user admin automatically
function ensureFirstAdmin() {
  const admins = getAdminEmails();
  if (admins.length === 0 && currentTrainee.email) {
    setAdminEmails([currentTrainee.email.toLowerCase()]);
  }
}

// ═══════════ AUTO-LOGIN ON PAGE LOAD ═══════════
(function() {
  try {
    var saved = localStorage.getItem('jem_onboarding_session');
    if (!saved) return;
    var session = JSON.parse(saved);
    if (!session.name || !session.email || !session.password) return;

    // Verify email domain
    if (!session.email.toLowerCase().endsWith('@jemhr.com')) {
      localStorage.removeItem('jem_onboarding_session');
      return;
    }

    // Verify saved password still matches the registry
    var pwStore = {};
    try { pwStore = JSON.parse(localStorage.getItem('jem_onboarding_passwords') || '{}'); } catch(e2) {}
    var emailKey = session.email.toLowerCase();
    if (pwStore[emailKey] && pwStore[emailKey] !== session.password) {
      // Password was changed — clear session, show login
      localStorage.removeItem('jem_onboarding_session');
      return;
    }

    // Pre-fill form fields
    document.getElementById('traineeEmail').value = session.email;
    document.getElementById('traineePassword').value = atob(session.password);

    // Auto-login after a brief moment so user sees the welcome screen flash
    var autoName = session.name || deriveNameFromEmail(session.email);
    setTimeout(function() {
      currentTrainee = { name: autoName, email: session.email };
      onboardingStartedAt = new Date();

      // Restore previous progress if available
      var records = getAllTraineeRecords();
      var existing = records.find(function(r) { return r.email === session.email; });
      if (existing && existing.moduleDetails) {
        existing.moduleDetails.forEach(function(md, i) {
          if (i < activityLog.length) {
            activityLog[i].status = md.status;
            activityLog[i].startedAt = md.startedAt;
            activityLog[i].completedAt = md.completedAt;
            activityLog[i].timeSpentMs = md.timeSpentMs || 0;
            if (md.status === 'completed') completedModules.add(i);
          }
        });
        quizScore = existing.quizScore || 0;
        if (existing.startedAt) onboardingStartedAt = new Date(existing.startedAt);
      }

      // Restore locked quiz answers
      restoreLockedAnswers();

      ensureFirstAdmin();
      saveTraineeRecord();

      document.getElementById('welcome').style.display = 'none';
      document.getElementById('app').classList.add('active');
      logModuleVisit(currentModule);
      buildSidebar();
      renderModule(currentModule);
    }, 300);
  } catch(e) {}
})();
</script>
