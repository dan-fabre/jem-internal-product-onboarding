function showOnePassToast() {
  var toast = document.getElementById('onepassToast');
  if (!toast) return;
  setTimeout(function() { toast.classList.add('show'); }, 800);
  // Auto-dismiss after 15 seconds
  window._onepassTimer = setTimeout(function() { dismissOnePassToast(); }, 15000);
}

function dismissOnePassToast() {
  var toast = document.getElementById('onepassToast');
  if (toast) toast.classList.remove('show');
  if (window._onepassTimer) clearTimeout(window._onepassTimer);
  try { sessionStorage.setItem('jem_onepass_dismissed', '1'); } catch(e) {}
}

function saveToOnePassword() {
  // Open 1Password vault — the browser extension will detect the form credentials
  // and offer to save them. We also trigger a form submission event so 1Password picks it up.
  var form = document.getElementById('loginForm');
  if (form) {
    // Dispatch a submit event so 1Password extension can capture credentials
    try {
      var evt = new Event('submit', { bubbles: true, cancelable: true });
      form.dispatchEvent(evt);
    } catch(e) {}
  }
  // Open 1Password web vault as fallback for manual save
  window.open('https://jemhr.1password.com/home?a=new', '_blank', 'noopener');
  dismissOnePassToast();
}

