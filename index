function startOnboarding() {
  const emailEl = document.getElementById('traineeEmail');
  const passEl = document.getElementById('traineePassword');
  const errEl = document.getElementById('welcomeError');
  const email = emailEl.value.trim();
  const password = passEl.value;

  // Validate — require email and password
  emailEl.classList.remove('error');
  passEl.classList.remove('error');
  errEl.classList.remove('show');

  if (!email || !email.toLowerCase().endsWith('@jemhr.com')) emailEl.classList.add('error');
  if (!password) passEl.classList.add('error');

  if (!email || !email.toLowerCase().endsWith('@jemhr.com') || !password) {
    if (email && !email.toLowerCase().endsWith('@jemhr.com')) {
      errEl.textContent = 'Only @jemhr.com email addresses are allowed.';
    }
    errEl.classList.add('show');
    return;
  }

  // Derive display name from email
  const name = deriveNameFromEmail(email);

  // Password verification
  var pwStore = {};
  try { pwStore = JSON.parse(localStorage.getItem('jem_onboarding_passwords') || '{}'); } catch(e) {}
  var emailKey = email.toLowerCase();
  var encodedPw = btoa(password);

  if (pwStore[emailKey]) {
    // Existing user — check password
    if (pwStore[emailKey] !== encodedPw) {
      passEl.classList.add('error');
      errEl.textContent = 'Incorrect password. Please try again or reset via Forgot password.';
      errEl.classList.add('show');
      return;
    }
  } else {
    // New user — register password
    pwStore[emailKey] = encodedPw;
    try { localStorage.setItem('jem_onboarding_passwords', JSON.stringify(pwStore)); } catch(e) {}
    // Prompt to save in 1Password for new users
    var wasDismissed = false;
    try { wasDismissed = sessionStorage.getItem('jem_onepass_dismissed') === '1'; } catch(e) {}
    if (!wasDismissed) {
      setTimeout(function() { showOnePassToast(); }, 1200);
    }
  }

  // Reset error text for next time
  errEl.textContent = 'Please enter your @jemhr.com email and password to begin.';

  currentTrainee = { name, email };
  onboardingStartedAt = new Date();

  // Save credentials if "Remember me" is checked
  var rememberMe = document.getElementById('rememberMe');
  if (rememberMe && rememberMe.checked) {
    try {
      localStorage.setItem('jem_onboarding_session', JSON.stringify({
        name: name,
        email: email,
        password: btoa(password)
      }));
    } catch(e) {}
  } else {
    localStorage.removeItem('jem_onboarding_session');
  }

  // Restore locked quiz answers from previous session
  restoreLockedAnswers();

  // Make first user admin automatically
  ensureFirstAdmin();

  // Save trainee record to localStorage
  saveTraineeRecord();

  document.getElementById('welcome').style.display = 'none';
  document.getElementById('app').classList.add('active');
  logModuleVisit(0);
  buildSidebar();
  renderModule(0);
}

function logoutOnboarding() {
  if (!confirm('Are you sure you want to log out? Your progress has been saved.')) return;

  // Save final state before logging out
  if (moduleEnteredAt !== null && activityLog[currentModule]) {
    activityLog[currentModule].timeSpentMs += Date.now() - moduleEnteredAt;
    moduleEnteredAt = null;
  }
  saveTraineeRecord();

  // Reset session state
  currentTrainee = { name: '', email: '' };
  currentModule = 0;
  completedModules = new Set();
  quizScore = 0;
  activityLog = modules.map((mod, i) => ({
    moduleIndex: i, title: mod.title, icon: mod.icon, section: mod.section,
    status: 'not-started', startedAt: null, lastVisitedAt: null, completedAt: null,
    timeSpentMs: 0, visitCount: 0
  }));
  onboardingStartedAt = null;
  collapsedSections = new Set();

  // Hide app, show welcome
  document.getElementById('app').classList.remove('active');
  document.getElementById('welcome').style.display = '';
  document.getElementById('sidebarUserFooter').style.display = 'none';

  // Clear saved session
  localStorage.removeItem('jem_onboarding_session');

  // Clear form inputs
  document.getElementById('traineeEmail').value = '';
  document.getElementById('traineePassword').value = '';
  document.getElementById('startBtn').disabled = true;
}

function buildSidebar() {
  const nav = document.getElementById('sidebarNav');
  let currentSection = '';
  let html = '';

  const collapsibleSections = ['Jem Dashboard', 'Admin Portal', 'Employee Channels'];
  let sectionOpen = false;

  modules.forEach((mod, i) => {
    if (mod.section !== currentSection) {
      // Close previous group if it was collapsible
      if (sectionOpen) { html += '</div>'; sectionOpen = false; }

      currentSection = mod.section;
      const isCollapsible = collapsibleSections.includes(currentSection);
      const sectionId = 'navSection_' + currentSection.replace(/\s+/g, '_');
      const isCollapsed = collapsedSections.has(currentSection);

      if (isCollapsible) {
        html += '<div class="nav-section-label collapsible' + (isCollapsed ? ' collapsed' : '') + '" onclick="toggleNavSection(\'' + currentSection.replace(/'/g, "\\'") + '\')">' +
          currentSection + '<span class="nav-section-chevron">▾</span></div>';
        html += '<div class="nav-section-group' + (isCollapsed ? ' collapsed' : '') + '" id="' + sectionId + '">';
        sectionOpen = true;
      } else {
        html += '<div class="nav-section-label">' + currentSection + '</div>';
      }
    }
    const isCompleted = completedModules.has(i);
    const isCurrent = i === currentModule;
    let cls = 'nav-item';
    if (isCurrent) cls += ' active';
    if (isCompleted) cls += ' completed';

    html += '<div class="' + cls + '" onclick="goToModule(' + i + ')">' +
      '<span class="nav-icon">' + mod.icon + '</span>' +
      '<span>' + mod.title + '</span></div>';
  });

  // Close last group if open
  if (sectionOpen) { html += '</div>'; }

  // Sidebar action buttons in grouped section
  html += '<div class="sidebar-actions">';
  html += '<div class="sidebar-actions-label">Tools</div>';
  html += '<button class="ask-toggle-btn" onclick="openAsk()">💬 Ask on Slack</button>';
  html += '<button class="log-toggle-btn" onclick="openLog()">📋 Progress Tracker</button>';
  if (isCurrentUserAdmin()) {
    const allRecords = getAllTraineeRecords();
    const countBadge = allRecords.length > 0 ? '<span class="admin-count-badge">' + allRecords.length + '</span>' : '';
    html += '<button class="admin-toggle-btn" onclick="openAdmin()">👩‍💼 Admin Log' + countBadge + '</button>';
    html += '<button class="settings-toggle-btn" onclick="openSettings()">⚙️ Settings</button>';
  }
  html += '<div style="height:1px;background:#e5e7eb;margin:8px 0;"></div>';
  html += '<button class="ask-toggle-btn" onclick="logoutOnboarding()" style="color:#ef4444">🚪 Log out</button>';
  html += '</div>';

  nav.innerHTML = html;
  updateProgress();

  // Update user footer
  if (currentTrainee.name) {
    const footer = document.getElementById('sidebarUserFooter');
    const initials = currentTrainee.name.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 2);
    const myRole = getUserRole(currentTrainee.email);
    const roleClass = myRole;
    const roleLabels = { 'super': 'Super User', 'admin': 'Admin', 'trainee': 'Trainee' };
    const roleLabel = roleLabels[myRole];
    footer.style.display = 'flex';
    footer.innerHTML = '<div class="sidebar-user-avatar">' + initials + '</div>' +
      '<div class="sidebar-user-info">' +
        '<div class="sidebar-user-name">' + escapeHtml(currentTrainee.name) + '</div>' +
        '<div class="sidebar-user-email">' + escapeHtml(currentTrainee.email) + '</div>' +
      '</div>' +
      '<span class="sidebar-user-role ' + roleClass + '">' + roleLabel + '</span>';
  }
}

function updateProgress() {
  const pct = Math.round((completedModules.size / modules.length) * 100);
  document.getElementById('progressText').textContent = pct + '%';
  document.getElementById('progressFill').style.width = pct + '%';
}

function renderModule(index) {
  // Track time spent on previous module
  if (moduleEnteredAt !== null && activityLog[currentModule]) {
    activityLog[currentModule].timeSpentMs += Date.now() - moduleEnteredAt;
  }
  moduleEnteredAt = Date.now();

  logModuleVisit(index);
  currentModule = index;
  const mod = modules[index];

  document.getElementById('breadcrumbModule').textContent = mod.title;
  document.getElementById('stepIndicator').textContent = 'Module ' + (index + 1) + ' of ' + modules.length;

  const container = document.getElementById('pageContent');

  if (mod.content === 'COMPLETION') {
    container.innerHTML = renderCompletion();
    buildSidebar();
    return;
  }

  let html = mod.content;

  // Add quiz if exists (from randomized bank)
  var activeQuiz = getActiveQuiz(index);
  if (activeQuiz) {
    html += renderQuiz(activeQuiz, index);
  }

  // Add navigation buttons
  html += '<div class="nav-buttons">' +
    '<button class="nav-btn nav-btn-prev" onclick="prevModule()" ' + (index === 0 ? 'disabled' : '') + '>← Previous</button>' +
    '<button class="nav-btn nav-btn-next" onclick="nextModule()">Next Module →</button>' +
    '</div>';

  container.innerHTML = html;
  initToggles();
  initVideoUploads(index);
  buildSidebar();
  window.scrollTo(0, 0);
}

function initToggles() {
  document.querySelectorAll('.content-card > h3').forEach(h3 => {
    // Skip if already set up
    if (h3.querySelector('.toggle-chevron')) return;

    // Add chevron indicator
    const chevron = document.createElement('span');
    chevron.className = 'toggle-chevron';
    chevron.textContent = '▾';
    h3.appendChild(chevron);

    // Wrap all siblings after h3 in a body div
    const card = h3.parentElement;
    const bodyWrap = document.createElement('div');
    bodyWrap.className = 'content-card-body';

    // Move all children after h3 into the body wrapper
    while (h3.nextSibling) {
      bodyWrap.appendChild(h3.nextSibling);
    }
    card.appendChild(bodyWrap);

    // Toggle on click
    h3.addEventListener('click', function() {
      card.classList.toggle('collapsed');
    });
  });
}

function renderQuiz(quiz, modIndex) {
  var isLocked = answeredQuizzes.has(modIndex) && lockedAnswers[modIndex];
  var lockData = isLocked ? lockedAnswers[modIndex] : null;

  let html = '<div class="quiz-section">' +
    '<h3>📝 Knowledge Check</h3>' +
    '<div class="quiz-question">' + quiz.question + '</div>' +
    '<div class="quiz-options" id="quizOptions_' + modIndex + '">';

  quiz.options.forEach((opt, i) => {
    var cls = 'quiz-option';
    var style = '';
    if (isLocked) {
      if (i === lockData.correct) cls += ' correct';
      else if (i === lockData.selected && lockData.selected !== lockData.correct) cls += ' incorrect';
      style = ' style="pointer-events:none;cursor:default;"';
    }
    var onclick = isLocked ? '' : ' onclick="checkAnswer(' + modIndex + ',' + i + ',' + quiz.correct + ')"';
    html += '<div class="' + cls + '"' + onclick + style + '>' + opt + '</div>';
  });

  html += '</div>';

  // Feedback messages
  var showCorrect = isLocked && lockData.selected === lockData.correct;
  var showIncorrect = isLocked && lockData.selected !== lockData.correct;
  html += '<div class="quiz-feedback correct-feedback' + (showCorrect ? ' show' : '') + '" id="correctFeedback_' + modIndex + '">✅ Correct! ' + quiz.explanation + '</div>';
  html += '<div class="quiz-feedback incorrect-feedback' + (showIncorrect ? ' show' : '') + '" id="incorrectFeedback_' + modIndex + '">❌ Not quite. ' + quiz.explanation + '</div>';

  // Locked badge
  html += '<div class="quiz-locked-badge" id="quizLockedBadge_' + modIndex + '" style="display:' + (isLocked ? 'inline-flex' : 'none') + '">' +
    '<span class="lock-icon">🔒</span> Answer Locked In</div>';

  html += '</div>';
  return html;
}

function checkAnswer(modIndex, selected, correct) {
  // If already locked in, do nothing
  if (answeredQuizzes.has(modIndex)) return;

  const options = document.querySelectorAll('#quizOptions_' + modIndex + ' .quiz-option');
  const alreadyAnswered = Array.from(options).some(o => o.classList.contains('correct') || o.classList.contains('incorrect'));
  if (alreadyAnswered) return;

  options.forEach((opt, i) => {
    if (i === correct) opt.classList.add('correct');
    else if (i === selected && selected !== correct) opt.classList.add('incorrect');
    opt.style.pointerEvents = 'none';
  });

  answeredQuizzes.add(modIndex);

  // Lock in the answer permanently
  lockedAnswers[modIndex] = { selected: selected, correct: correct };
  saveLockedAnswers();

  if (selected === correct) {
    document.getElementById('correctFeedback_' + modIndex).classList.add('show');
    quizScore++;
  } else {
    document.getElementById('incorrectFeedback_' + modIndex).classList.add('show');
  }

  // Show locked badge
  var lockBadge = document.getElementById('quizLockedBadge_' + modIndex);
  if (lockBadge) lockBadge.style.display = 'inline-flex';

  completedModules.add(modIndex);
  logModuleComplete(modIndex);
  saveTraineeRecord();
  buildSidebar();
}

function nextModule() {
  completedModules.add(currentModule);
  logModuleComplete(currentModule);
  saveTraineeRecord();
  if (currentModule < modules.length - 1) {
    renderModule(currentModule + 1);
  }
}

function prevModule() {
  if (currentModule > 0) {
    renderModule(currentModule - 1);
  }
}

function goToModule(index) {
  renderModule(index);
}

function toggleNavSection(sectionName) {
  if (collapsedSections.has(sectionName)) {
    collapsedSections.delete(sectionName);
  } else {
    collapsedSections.add(sectionName);
  }
  buildSidebar();
}

