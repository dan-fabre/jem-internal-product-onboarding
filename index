  /* ─── Completion Screen ─── */
  .completion-screen {
    text-align: center;
    padding: 80px 40px;
    position: relative;
    overflow: hidden;
  }

  /* Confetti canvas sits behind content */
  .confetti-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }
  .completion-screen > *:not(.confetti-canvas) {
    position: relative;
    z-index: 1;
  }

  .completion-icon {
    width: 110px;
    height: 110px;
    background: linear-gradient(135deg, var(--jem-green), #059669);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 52px;
    margin: 0 auto 24px;
    animation: icon-entrance 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    box-shadow: 0 8px 30px rgba(16, 185, 129, 0.3);
  }

  @keyframes icon-entrance {
    0% { transform: scale(0) rotate(-20deg); opacity: 0; }
    60% { transform: scale(1.15) rotate(5deg); opacity: 1; }
    80% { transform: scale(0.95) rotate(-2deg); }
    100% { transform: scale(1) rotate(0deg); }
  }

  /* Pulsing glow on completion icon */
  .completion-icon::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--jem-green), #059669);
    opacity: 0;
    z-index: -1;
    animation: icon-pulse 2s ease-in-out 0.8s infinite;
  }
  @keyframes icon-pulse {
    0%, 100% { opacity: 0; transform: scale(1); }
    50% { opacity: 0.2; transform: scale(1.15); }
  }

  .completion-screen h2 {
    font-size: 32px;
    font-weight: 800;
