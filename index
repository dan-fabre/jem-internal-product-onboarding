    display: flex;
    align-items: center;
    gap: 14px;
    max-width: 400px;
    transform: translateY(120%);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
  }
  .onepass-toast.show {
    transform: translateY(0);
    opacity: 1;
  }
  .onepass-toast-icon {
