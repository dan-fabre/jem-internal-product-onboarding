      // Insert after video-caption if it exists, otherwise after video-wrapper
      var caption = section.querySelector('.video-caption');
      if (caption) {
        caption.after(uploadArea);
      } else {
        wrapper.after(uploadArea);
      }
    }
  });
}

// ═══════════ CONFETTI ANIMATION ═══════════
function launchConfetti() {
  var cvs = document.getElementById('confettiCanvas');
  if (!cvs) return;
  var ctx = cvs.getContext('2d');
  var W = cvs.parentElement.offsetWidth;
  var H = cvs.parentElement.offsetHeight;
  cvs.width = W;
  cvs.height = H;

  var colors = ['#F27B8A','#10b981','#3b82f6','#f59e0b','#8b5cf6','#ec4899','#06b6d4','#f97316'];
  var shapes = ['rect','circle','strip'];
  var particles = [];
  var count = 150;

  for (var i = 0; i < count; i++) {
    particles.push({
      x: Math.random() * W,
      y: Math.random() * -H,
      w: Math.random() * 8 + 4,
      h: Math.random() * 6 + 3,
      color: colors[Math.floor(Math.random() * colors.length)],
      shape: shapes[Math.floor(Math.random() * shapes.length)],
      vx: (Math.random() - 0.5) * 3,
      vy: Math.random() * 3 + 2,
      rot: Math.random() * Math.PI * 2,
      rv: (Math.random() - 0.5) * 0.15,
      opacity: Math.random() * 0.4 + 0.6
    });
  }

  var frames = 0;
  var maxFrames = 300;

  function draw() {
    if (frames > maxFrames) { ctx.clearRect(0, 0, W, H); return; }
    ctx.clearRect(0, 0, W, H);
    var fade = frames > maxFrames - 60 ? (maxFrames - frames) / 60 : 1;

    for (var i = 0; i < particles.length; i++) {
      var p = particles[i];
      p.x += p.vx;
      p.vy += 0.04;
      p.y += p.vy;
      p.rot += p.rv;
      p.vx *= 0.99;

      if (p.y > H + 20) {
        p.y = -10;
        p.x = Math.random() * W;
        p.vy = Math.random() * 2 + 1;
      }

      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(p.rot);
      ctx.globalAlpha = p.opacity * fade;
      ctx.fillStyle = p.color;

      if (p.shape === 'rect') {
        ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
      } else if (p.shape === 'circle') {
        ctx.beginPath();
        ctx.arc(0, 0, p.w / 2, 0, Math.PI * 2);
        ctx.fill();
      } else {
        ctx.fillRect(-p.w / 2, -1, p.w, 2.5);
      }
      ctx.restore();
    }

    frames++;
    requestAnimationFrame(draw);
  }
  draw();
}

