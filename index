// ─── Password Strength Checker ───
function checkPasswordStrength(pw) {
  var wrap = document.getElementById('pwStrengthWrap');
  var fill = document.getElementById('pwStrengthFill');
  var label = document.getElementById('pwStrengthLabel');
  if (!pw) { wrap.style.display = 'none'; return; }
  wrap.style.display = 'block';

  var hasLen = pw.length >= 8;
  var hasUpper = /[A-Z]/.test(pw);
  var hasLower = /[a-z]/.test(pw);
  var hasNum = /[0-9]/.test(pw);
  var hasSpecial = /[^A-Za-z0-9]/.test(pw);

  // Update requirement indicators
  var reqs = [
    { id: 'pwReqLen', met: hasLen },
    { id: 'pwReqUpper', met: hasUpper },
    { id: 'pwReqLower', met: hasLower },
    { id: 'pwReqNum', met: hasNum },
    { id: 'pwReqSpecial', met: hasSpecial }
  ];
  reqs.forEach(function(r) {
    var el = document.getElementById(r.id);
    if (!el) return;
    if (r.met) {
      el.classList.add('met');
      el.querySelector('.pw-req-icon').textContent = '✓';
    } else {
      el.classList.remove('met');
      el.querySelector('.pw-req-icon').textContent = '○';
    }
  });

  var score = (hasLen ? 1 : 0) + (hasUpper ? 1 : 0) + (hasLower ? 1 : 0) + (hasNum ? 1 : 0) + (hasSpecial ? 1 : 0);
  if (pw.length >= 12) score += 1;
  if (pw.length >= 16) score += 1;

  var levels = [
    { max: 1, pct: 15, color: '#ef4444', text: 'Very weak' },
    { max: 2, pct: 30, color: '#f97316', text: 'Weak' },
    { max: 3, pct: 50, color: '#f59e0b', text: 'Fair' },
    { max: 5, pct: 75, color: '#3b82f6', text: 'Strong' },
    { max: 99, pct: 100, color: '#10b981', text: 'Very strong' }
  ];
  var lvl = levels[0];
  for (var i = 0; i < levels.length; i++) {
    if (score <= levels[i].max) { lvl = levels[i]; break; }
  }
  fill.style.width = lvl.pct + '%';
  fill.style.background = lvl.color;
  label.textContent = lvl.text;
  label.style.color = lvl.color;
}

function suggestStrongPassword() {
  var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
  var specials = '!@#$%&*?+-=';
  var pw = '';
  // Guarantee at least one of each type
  pw += 'ABCDEFGHJKLMNPQRSTUVWXYZ'[Math.floor(Math.random() * 24)];
  pw += 'abcdefghjkmnpqrstuvwxyz'[Math.floor(Math.random() * 23)];
  pw += '23456789'[Math.floor(Math.random() * 8)];
  pw += specials[Math.floor(Math.random() * specials.length)];
  // Fill to 14 characters
  for (var i = pw.length; i < 14; i++) {
    var pool = chars + specials;
    pw += pool[Math.floor(Math.random() * pool.length)];
  }
  // Shuffle
  pw = pw.split('').sort(function() { return Math.random() - 0.5; }).join('');

  var inp = document.getElementById('traineePassword');
  inp.value = pw;
  inp.type = 'text';
  var togBtn = inp.nextElementSibling;
  if (togBtn) togBtn.textContent = '🙈';

  checkPasswordStrength(pw);
  checkWelcomeForm();

  // Brief highlight effect
  inp.style.background = 'rgba(16, 185, 129, 0.15)';
  inp.style.borderColor = '#10b981';
  setTimeout(function() {
    inp.style.background = '';
    inp.style.borderColor = '';
  }, 1500);
}

