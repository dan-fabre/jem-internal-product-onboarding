function sendSlackQuestion() {
  const question = (document.getElementById('askQuestion').value || '').trim();
  const msgEl = document.getElementById('askMsg');
  const btn = document.getElementById('askSendBtn');
  const webhook = getSlackWebhook();

  if (!question) {
    msgEl.className = 'ask-msg error';
    msgEl.textContent = 'Please type a question first.';
    return;
  }

  if (!webhook) {
    msgEl.className = 'ask-msg error';
    msgEl.textContent = 'No webhook configured. Ask your admin to set it up.';
    return;
  }

  const mod = modules[currentModule];
  const channel = getSlackChannel();

  const payload = {
    text: '📩 *Onboarding Question*',
    blocks: [
      {
        type: 'section',
        text: {
          type: 'mrkdwn',
          text: '📩 *New Onboarding Question*'
        }
      },
      {
        type: 'section',
        fields: [
          { type: 'mrkdwn', text: '*From:*\n' + currentTrainee.name + ' (' + currentTrainee.email + ')' },
          { type: 'mrkdwn', text: '*Module:*\n' + mod.icon + ' ' + mod.title }
        ]
      },
      {
        type: 'section',
        text: {
          type: 'mrkdwn',
          text: '*Question:*\n' + question
        }
      },
      {
        type: 'context',
        elements: [
          { type: 'mrkdwn', text: '🕐 ' + new Date().toLocaleString() + ' • via Jem Onboarding Tool' }
        ]
      }
    ]
  };

  // Show sending state
  msgEl.className = 'ask-msg sending';
  msgEl.textContent = 'Sending...';
  btn.disabled = true;

  fetch(webhook, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    mode: 'no-cors',
    body: JSON.stringify(payload)
  }).then(() => {
    msgEl.className = 'ask-msg success';
    msgEl.textContent = 'Sent to ' + channel + '!';
    document.getElementById('askQuestion').value = '';
    btn.disabled = false;
  }).catch(err => {
    msgEl.className = 'ask-msg error';
    msgEl.textContent = 'Failed to send. Check webhook URL.';
    btn.disabled = false;
  });
}

function renderCompletion() {
  // Check if all quizzes have been answered
  var quizModuleIndices = [];
  modules.forEach(function(m, i) {
    if (m.quizBank && m.quizBank.length > 0) quizModuleIndices.push(i);
  });
  var unanswered = quizModuleIndices.filter(function(i) { return !answeredQuizzes.has(i); });

  if (unanswered.length > 0) {
    // Not all quizzes answered — show sad face
    var missingList = unanswered.map(function(i) {
      return '<div class="incomplete-quiz-item" onclick="goToModule(' + i + ')">' +
        '<span class="incomplete-quiz-icon">' + modules[i].icon + '</span>' +
        '<span class="incomplete-quiz-title">' + modules[i].title + '</span>' +
        '<span class="incomplete-quiz-arrow">→</span>' +
      '</div>';
    }).join('');

    return '<div class="completion-screen incomplete-screen">' +
      '<div class="incomplete-face">😢</div>' +
      '<h2>Not so fast!</h2>' +
      '<p>You haven\'t answered all the quiz questions yet. Please go back and complete the quizzes in the following modules before finishing your onboarding.</p>' +
      '<div class="incomplete-count">' + unanswered.length + ' quiz' + (unanswered.length !== 1 ? 'zes' : '') + ' remaining</div>' +
      '<div class="incomplete-quiz-list">' + missingList + '</div>' +
      '<p style="font-size:13px; color:#9ca3af; margin-top:16px;">Click on a module above to jump directly to it.</p>' +
    '</div>';
  }

  // All quizzes answered — check if PERFECT score
  var isPerfect = quizScore === totalQuizzes;

  if (!isPerfect) {
    // Not a perfect score — show sad face with score and retry
    var wrongCount = totalQuizzes - quizScore;
    return '<div class="completion-screen incomplete-screen">' +
      '<div class="incomplete-face">😢</div>' +
      '<h2>Almost there!</h2>' +
      '<p>You answered all the quizzes but didn\'t get a perfect score. You need <strong>100%</strong> to earn your certificate.</p>' +
      '<div class="score-card" style="margin:20px auto;">' +
        '<h3>Your Score</h3>' +
        '<div class="score-value" style="color:#ef4444;">' + quizScore + '/' + totalQuizzes + '</div>' +
      '</div>' +
      '<div class="incomplete-count" style="margin-bottom:16px;">' + wrongCount + ' incorrect answer' + (wrongCount !== 1 ? 's' : '') + '</div>' +
      '<p style="font-size:14px; color:#6b7280; max-width:500px; margin:0 auto 20px;">Don\'t worry — you can restart and try again. The questions will be different next time so make sure you review the modules carefully!</p>' +
      '<div class="completion-actions">' +
        '<button class="restart-btn" onclick="restartOnboarding()" style="background:var(--jem-red);color:white;border-color:var(--jem-red);">↻ Try Again</button>' +
      '</div>' +
    '</div>';
  }

  // PERFECT SCORE — show celebration!
  completedModules.add(currentModule);
  logModuleComplete(currentModule);
  saveTraineeRecord();
  updateProgress();

  setTimeout(function() { launchConfetti(); }, 200);

  return '<div class="completion-screen">' +
    '<canvas class="confetti-canvas" id="confettiCanvas"></canvas>' +
    '<div class="completion-icon">🎉</div>' +
    '<h2>Onboarding Complete!</h2>' +
    '<p>Congratulations! You achieved a <strong>perfect score</strong> and completed the Jem HR product onboarding. You\'re now ready to start working with the platform confidently.</p>' +
    '<div class="score-card">' +
    '<h3>Quiz Score</h3>' +
    '<div class="score-value" style="color:var(--jem-green);">' + quizScore + '/' + totalQuizzes + ' ⭐</div>' +
    '</div>' +
    '<p style="font-size:14px; color: #6b7280;">Remember: the <strong>Help Center</strong> is always available in the Dashboard sidebar if you need a refresher. Contact <strong>customersuccess@jemhr.com</strong> for any support needs.</p>' +
    '<div class="completion-actions">' +
    '<button class="cert-btn" onclick="downloadCertificate()">🎓 Download Certificate</button>' +
    '<button class="restart-btn" onclick="restartOnboarding()">↻ Restart Onboarding</button>' +
    '</div>' +
    '</div>';
}

function restartOnboarding() {
  currentModule = 0;
  completedModules = new Set();
  answeredQuizzes = new Set();
  lockedAnswers = {};
  quizScore = 0;
  // Clear locked answers from storage
  var lockKey = getLockedAnswersKey();
  if (lockKey) try { localStorage.removeItem(lockKey); } catch(e) {}
  // Randomize new questions for next attempt
  selectRandomQuizzes();
  activityLog = modules.map((mod, i) => ({
    moduleIndex: i, title: mod.title, icon: mod.icon, section: mod.section,
    status: 'not-started', startedAt: null, lastVisitedAt: null, completedAt: null,
    timeSpentMs: 0, visitCount: 0
  }));
  moduleEnteredAt = null;
  onboardingStartedAt = new Date();
  saveTraineeRecord();
  logModuleVisit(0);
  renderModule(0);
}

