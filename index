function saveTraineeRecord() {
  const records = getAllTraineeRecords();
  const completed = activityLog.filter(e => e.status === 'completed').length;
  const total = activityLog.length;
  const totalTime = activityLog.reduce((sum, e) => sum + e.timeSpentMs, 0);

  let overall = 'not-started';
  if (completed === total) overall = 'completed';
  else if (activityLog.some(e => e.status !== 'not-started')) overall = 'in-progress';

  // Find existing record by email or create new
  const idx = records.findIndex(r => r.email === currentTrainee.email);
  const record = {
    name: currentTrainee.name,
    email: currentTrainee.email,
    overallStatus: overall,
    startedAt: onboardingStartedAt ? onboardingStartedAt.toISOString() : null,
    lastActiveAt: new Date().toISOString(),
    completedAt: overall === 'completed' ? new Date().toISOString() : (idx >= 0 && records[idx].completedAt ? records[idx].completedAt : null),
    modulesCompleted: completed,
    totalModules: total,
    quizScore: quizScore,
    totalQuizzes: totalQuizzes,
    totalTimeMs: totalTime,
    moduleDetails: activityLog.map(e => ({
      title: e.title,
      status: e.status,
      startedAt: e.startedAt ? e.startedAt.toISOString ? e.startedAt.toISOString() : e.startedAt : null,
      completedAt: e.completedAt ? e.completedAt.toISOString ? e.completedAt.toISOString() : e.completedAt : null,
      timeSpentMs: e.timeSpentMs
    }))
  };

  if (idx >= 0) {
    records[idx] = record;
  } else {
    records.push(record);
  }

  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(records)); } catch(e) {}
}

